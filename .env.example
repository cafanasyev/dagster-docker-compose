# Postgres credentials for Dagster run/schedule/event-log storage
DAGSTER_POSTGRES_USER=postgres_user
DAGSTER_POSTGRES_PASSWORD=postgres_password
DAGSTER_POSTGRES_DB=postgres_db

# Your create-dagster project = build context for the user-code image
DAGSTER_PROJECT_PATH=../my-project
# Code location module; loaded as <module>.definitions
DAGSTER_MODULE=my_project
# Path to this template's Dockerfile_user_code, relative to DAGSTER_PROJECT_PATH
DAGSTER_DOCKERFILE_USER_CODE=../dagster-docker-compose/Dockerfile_user_code

# User-code image name (also used as DAGSTER_CURRENT_IMAGE)
DAGSTER_USER_CODE_IMAGE=dagster_user_code_image

# Python version for both images (must satisfy the project's requires-python)
PYTHON_VERSION=3.13

# Host port for the Dagster webserver UI (container side stays 3000)
DAGSTER_WEBSERVER_PORT=3000